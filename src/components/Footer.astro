---
interface Props {
  siteName?: string;
}
const { siteName = 'SEOplant' } = Astro.props;
---

<footer class="site-footer">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-brand">
        <a href="/" class="footer-logo">{siteName}</a>
        <p>AI Programmatic SEO Platform. From keyword to ranking website.</p>
        <div class="footer-social">
          <a href="https://github.com/seoplant/seoplant" aria-label="GitHub">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
          </a>
        </div>
      </div>
      <div>
        <h4>Product</h4>
        <a href="/docs">Documentation</a>
        <a href="/pricing">Pricing</a>
        <a href="https://app.seoplant.io/dashboard">Dashboard</a>
        <a href="https://github.com/seoplant/seoplant">GitHub</a>
      </div>
      <div>
        <h4>Compare</h4>
        <a href="/vs/byword">vs Byword</a>
        <a href="/vs/surfer-seo">vs Surfer SEO</a>
      </div>
      <div>
        <h4>Company</h4>
        <a href="/about">About</a>
        <a href="/blog">Blog</a>
        <a href="mailto:hello@seoplant.io">Contact</a>
        <a href="https://github.com/seoplant/seoplant">GitHub</a>
      </div>
    </div>
    <div class="footer-bottom">
      <p>&copy; {new Date().getFullYear()} {siteName}. All rights reserved.</p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--color-dark);
    color: var(--color-text-inverse);
    padding-block: var(--space-3xl) var(--space-xl);
  }
  .footer-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: var(--space-2xl);
    margin-bottom: var(--space-3xl);
  }
  .footer-brand p {
    color: var(--color-text-muted);
    font-size: 0.9rem;
    margin-top: var(--space-sm);
    max-width: 260px;
  }
  .footer-logo {
    font-family: var(--font-heading);
    font-size: 1.3rem;
    font-weight: 700;
    color: var(--color-text-inverse);
    text-decoration: none;
  }
  .footer-social { margin-top: var(--space-md); }
  .footer-social a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px; height: 36px;
    border-radius: 50%;
    background: rgba(255,255,255,0.08);
    color: var(--color-text-muted);
    transition: all var(--transition-fast);
  }
  .footer-social a:hover {
    background: rgba(255,255,255,0.15);
    color: var(--color-text-inverse);
  }
  .footer-grid h4 {
    color: var(--color-text-inverse);
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: var(--space-md);
  }
  .footer-grid a {
    display: block;
    color: var(--color-text-muted);
    font-size: 0.9rem;
    padding: 4px 0;
    transition: color var(--transition-fast);
  }
  .footer-grid a:hover {
    color: var(--color-text-inverse);
    text-decoration: none;
  }
  .footer-bottom {
    border-top: 1px solid rgba(255,255,255,0.08);
    padding-top: var(--space-lg);
    text-align: center;
  }
  .footer-bottom p {
    color: var(--color-text-muted);
    font-size: 0.85rem;
    margin: 0;
  }
  @media (max-width: 768px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
    }
  }
</style>
