---
import BaseLayout from '../../layouts/BaseLayout.astro';

const posts = [
  {
    title: "Programmatic SEO in 2026: The Complete Guide to Scaling Content with AI",
    slug: "programmatic-seo-guide-2026",
    date: "2026-05-25",
    excerpt: "How to generate thousands of SEO pages that actually rank. A practical guide to programmatic SEO with AI — strategy, templates, tools, and pitfalls.",
    tags: ["Programmatic SEO", "AI", "Strategy"],
  },
  {
    title: "How We Built SEOplant — 14 Days from Idea to Live Product",
    slug: "building-seoplant-14-days",
    date: "2026-05-25",
    excerpt: "From a ChatGPT conversation to a deployed SaaS with competitor analysis, SEO engine, and live dashboard — all in 14 days with AI-assisted development.",
    tags: ["Build in Public", "SaaS"],
  },
  {
    title: "Why AI Website Builders Fail at SEO",
    slug: "why-ai-website-builders-fail-seo",
    date: "2026-05-24",
    excerpt: "Durable, 10Web, and Wix AI can build you a site in 30 seconds. But here's why none of those sites will ever rank on Google.",
    tags: ["SEO", "AI"],
  },
];
---

<BaseLayout
  title="Blog — SEOplant"
  description="Articles about programmatic SEO, AI content strategy, website generation, and building sites that rank."
>

  <section class="section">
    <div class="container" style="max-width:720px;">
      <h1>SEOplant Blog</h1>
      <p style="color:var(--color-text-muted); margin-bottom:var(--space-2xl);">
        Programmatic SEO, AI content strategy, and the future of website building.
      </p>

      {posts.map(post => (
        <article style="margin-bottom:var(--space-2xl);padding-bottom:var(--space-2xl);border-bottom:1px solid var(--color-border);">
          <div class="tags">
            {post.tags.map(t => <span class="tag">{t}</span>)}
          </div>
          <h2 style="margin:var(--space-sm) 0;">
            <a href={`/blog/${post.slug}`} style="text-decoration:none;">{post.title}</a>
          </h2>
          <time style="font-size:0.85rem;color:var(--color-text-muted);">{post.date}</time>
          <p style="margin-top:var(--space-sm);color:var(--color-text-muted);">{post.excerpt}</p>
          <a href={`/blog/${post.slug}`} style="font-weight:600;">Read more -></a>
        </article>
      ))}

    </div>
  </section>

</BaseLayout>

<style>
  .tags { display: flex; gap: var(--space-sm); }
  .tag {
    font-size: 0.75rem; padding: 2px 10px; border-radius: 100px;
    background: var(--color-surface); border: 1px solid var(--color-border);
    color: var(--color-text-muted);
  }
</style>
