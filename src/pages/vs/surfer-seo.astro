  td.win { color: #059669; font-weight: 600; }
  td.lose { color: var(--color-text-muted); }
  ul { padding-left: 20px; }
  li { margin-bottom: 6px; }
  .btn { display: inline-flex; align-items: center; gap: 8px; padding: 10px 22px; border-radius: 8px; font-weight: 600; font-size: 0.95rem; cursor: pointer; border: none; text-decoration: none; }
  .btn-primary { background: var(--color-primary); color: #fff; }
  .btn-secondary { background: transparent; color: var(--color-primary); border: 2px solid var(--color-primary); }
</style>
