---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="SEOplant — AI Programmatic SEO Platform"
  description="Turn a keyword into a fully SEO-optimized website. Competitor analysis, topic clusters, programmatic pages, and one-click deployment. Open source."
>

  <!-- Hero -->
  <section class="hero">
    <div class="glow-orb" style="width:600px;height:600px;background:radial-gradient(circle,#3B82F6,transparent);top:-200px;left:-100px;"></div>
    <div class="glow-orb" style="width:400px;height:400px;background:radial-gradient(circle,#8B5CF6,transparent);bottom:-100px;right:-50px;opacity:0.12;"></div>
    <div class="container">
      <div class="hero-content">
        <span class="badge" style="margin-bottom:var(--space-xl);">Open Source + SaaS</span>
        <h1>From <span class="gradient-text">Keyword</span> to<br/>Ranking Website</h1>
        <p class="hero-sub">
          Enter a niche. AI analyzes competitors, builds an SEO strategy,
          generates programmatic pages, and deploys your site.
          No code. No lock-in.
        </p>
        <div class="hero-actions">
          <a href="https://app.seoplant.io/register" class="btn btn-primary btn-lg">Start Building Free</a>
          <a href="https://github.com/seoplant/seoplant" class="btn btn-secondary btn-lg">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
            3,200 GitHub Stars
          </a>
        </div>
        <div class="hero-terminal">
          <div class="terminal-bar"><span></span><span></span><span></span></div>
          <pre><code><span class="dim">$</span> python seo_engine.py plan <span class="kw">"best hiking boots"</span> --type ecommerce

<span class="dim">Analyzing competitors... 20 sites crawled</span>
<span class="dim">Generating SEO strategy... 69 keywords, 3 topic clusters</span>

<span class="green">Site ready:</span> hikinggearpro.com <span class="dim">(500 pages, deployed)</span></code></pre>
        </div>
      </div>
    </div>
  </section>

  <!-- Logos / Social Proof -->
  <section class="section" style="padding-block:var(--space-2xl);border-bottom:1px solid var(--color-border-light);">
    <div class="container" style="text-align:center;">
      <p style="color:var(--color-text-muted);font-size:0.85rem;margin-bottom:var(--space-lg);text-transform:uppercase;letter-spacing:0.05em;">Built with</p>
      <div style="display:flex;gap:var(--space-2xl);justify-content:center;align-items:center;flex-wrap:wrap;opacity:0.6;">
        <span style="font-weight:700;font-size:1.1rem;">Python</span>
        <span style="font-weight:700;font-size:1.1rem;">Astro</span>
        <span style="font-weight:700;font-size:1.1rem;">FastAPI</span>
        <span style="font-weight:700;font-size:1.1rem;">Real-time SEO data</span>
        <span style="font-weight:700;font-size:1.1rem;">Cloudflare</span>
        <span style="font-weight:700;font-size:1.1rem;">Stripe</span>
      </div>
    </div>
  </section>

  <!-- Problem + Solution -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <span class="section-label">The Problem</span>
        <h2>AI website builders make pretty sites.<br/>They don't make sites that <span class="gradient-text">rank</span>.</h2>
        <p style="font-size:1.15rem;max-width:700px;margin:0 auto;">Every tool solves half the problem. We solve the whole thing.</p>
      </div>

      <div class="grid cols-3" style="margin-top:var(--space-3xl);">
        <div class="feature-card">
          <div class="feature-icon" style="background:#fee2e2;">A</div>
          <h3>AI Builders</h3>
          <p>Durable, 10Web, Wix AI generate pages in 30 seconds. But <strong>zero SEO intelligence</strong> — no keywords, no strategy, no rankings.</p>
          <span class="feature-tag" style="color:#dc2626;background:#fef2f2;">Pretty but invisible</span>
        </div>
        <div class="feature-card">
          <div class="feature-icon" style="background:#fef3c7;">B</div>
          <h3>SEO Tools</h3>
          <p>Byword, Surfer, Frase do great content research and writing. But <strong>they can't build a website</strong>. You still need to code, host, and deploy.</p>
          <span class="feature-tag" style="color:#d97706;background:#fffbeb;">Content without a home</span>
        </div>
        <div class="feature-card">
          <div class="feature-icon" style="background:#dbeafe;">C</div>
          <h3>App Builders</h3>
          <p>Base44, Lovable, Bolt.new build apps from prompts. <strong>Not designed for SEO content sites.</strong> No keyword research, no schema, no sitemaps.</p>
          <span class="feature-tag" style="color:#2563eb;background:#eff6ff;">Wrong tool for SEO</span>
        </div>
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section class="section" style="background:var(--color-dark);color:var(--color-text-inverse);position:relative;overflow:hidden;">
    <div class="glow-orb" style="width:500px;height:500px;background:radial-gradient(circle,#3B82F6,transparent);top:50%;left:50%;transform:translate(-50%,-50%);opacity:0.08;"></div>
    <div class="container" style="position:relative;z-index:1;">
      <div class="section-header">
        <span class="section-label">How It Works</span>
        <h2 style="color:var(--color-text-inverse);">One keyword. 5 minutes.</h2>
        <p style="color:var(--color-text-muted);font-size:1.15rem;">A complete, deployed, SEO-optimized website.</p>
      </div>

      <div class="steps" style="margin-top:var(--space-3xl);">
        <div class="step">
          <div class="step-num">1</div>
          <h4>Enter a Niche</h4>
          <p>"Best hiking boots", "London dentist", "Scottish Highlands travel" — any niche, any language.</p>
        </div>
        <div class="step-connector"></div>
        <div class="step">
          <div class="step-num">2</div>
          <h4>AI Analyzes the Market</h4>
          <p>Crawls top 20 competitors. Extracts URL structure, schema, content depth, and keyword gaps.</p>
        </div>
        <div class="step-connector"></div>
        <div class="step">
          <div class="step-num">3</div>
          <h4>Strategy Generated</h4>
          <p>Topic clusters, 6-month content calendar, programmatic SEO templates with real search volume data.</p>
        </div>
        <div class="step-connector"></div>
        <div class="step">
          <div class="step-num">4</div>
          <h4>Site Built + Deployed</h4>
          <p>Astro site with Schema, llms.txt, and 50-5000 pages. One click to your VPS or Cloudflare.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Features Grid -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <span class="section-label">Features</span>
        <h2>Everything you need to<br/><span class="gradient-text">rank and scale</span></h2>
      </div>

      <div class="grid cols-2" style="margin-top:var(--space-3xl);">
        <div class="feature-card">
          <h3>&#128269; Competitor Teardown Engine</h3>
          <p>Automatically crawls and analyzes competitors — URL structure, schema markup, content depth, internal linking, and keyword strategy. Then builds a better version.</p>
        </div>
        <div class="feature-card">
          <h3>&#9889; Programmatic SEO at Scale</h3>
          <p>One keyword becomes thousands of pages. City landing pages, product comparisons, FAQ sections — generated from templates + structured data with content variation.</p>
        </div>
        <div class="feature-card">
          <h3>&#127760; SEO-First Architecture</h3>
          <p>Every page is built for ranking: clean URLs, proper heading hierarchy, Schema.org structured data, llms.txt for AI search engines, and automatic internal linking.</p>
        </div>
        <div class="feature-card">
          <h3>&#128640; Bring Your Own VPS</h3>
          <p>No platform lock-in. Deploy to your $5/month VPS via SSH. Or use Vercel, Netlify, Cloudflare. Your code, your server, your data. Always.</p>
        </div>
        <div class="feature-card">
          <h3>&#129302; GEO + AI Search Built-In</h3>
          <p>Optimized for ChatGPT, Perplexity, Gemini, and Google AI Overviews. Auto-generated llms.txt, structured data for AI citation, and AI visibility tracking.</p>
        </div>
        <div class="feature-card">
          <h3>&#128187; 100% Open Source</h3>
          <p>All modules MIT licensed. No vendor lock-in. The cloud version adds real SEO data, agent orchestration, and autonomous rank monitoring.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Comparison Table -->
  <section class="section" style="background:var(--color-surface);">
    <div class="container">
      <div class="section-header">
        <span class="section-label">Compare</span>
        <h2>How we stack up</h2>
      </div>
      <div class="table-wrap" style="margin-top:var(--space-2xl);">
        <table>
          <thead>
            <tr><th></th><th class="us">SEOplant</th><th>Byword</th><th>Surfer SEO</th><th>10Web</th><th>Lovable</th></tr>
          </thead>
          <tbody>
            <tr><td>Competitor Analysis</td><td class="yes">Auto</td><td class="no">—</td><td class="no">—</td><td class="no">—</td><td class="no">—</td></tr>
            <tr><td>SEO Strategy</td><td class="yes">Auto</td><td class="no">—</td><td class="partial">Manual</td><td class="no">—</td><td class="no">—</td></tr>
            <tr><td>Website Building</td><td class="yes">Astro SSG</td><td class="no">—</td><td class="no">—</td><td class="yes">WordPress</td><td class="yes">React</td></tr>
            <tr><td>Programmatic SEO</td><td class="yes">Template engine</td><td class="yes">Articles only</td><td class="no">—</td><td class="no">—</td><td class="no">—</td></tr>
            <tr><td>Code Export</td><td class="yes">Full export</td><td class="no">—</td><td class="no">—</td><td class="partial">WP only</td><td class="yes">Full</td></tr>
            <tr><td>GEO Optimization</td><td class="yes">Built-in</td><td class="no">—</td><td class="partial">Add-on</td><td class="no">—</td><td class="no">—</td></tr>
            <tr><td>Open Source</td><td class="yes">MIT</td><td class="no">—</td><td class="no">—</td><td class="no">—</td><td class="no">—</td></tr>
            <tr><td>Starting Price</td><td class="yes"><strong>Free</strong></td><td>$99/mo</td><td>$79/mo</td><td>$10/mo</td><td>$20/mo</td></tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Pricing -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <span class="section-label">Pricing</span>
        <h2>Start free, scale as you grow</h2>
      </div>
      <div class="grid cols-3" style="margin-top:var(--space-3xl);align-items:stretch;">
        <div class="pricing-card">
          <h3>Open Source</h3>
          <div class="price">Free</div>
          <p class="price-sub">MIT License. Self-hosted.</p>
          <ul>
            <li>5 pipeline modules</li>
            <li>Heuristic SEO analysis</li>
            <li>Astro site generation</li>
            <li>VPS/Cloud deployment</li>
            <li>Community support</li>
          </ul>
          <a href="https://github.com/seoplant/seoplant" class="btn btn-secondary" style="width:100%;">GitHub</a>
        </div>
        <div class="pricing-card featured">
          <div class="featured-badge">Most Popular</div>
          <h3>Cloud</h3>
          <div class="price">$79<span>/mo</span></div>
          <p class="price-sub">Real data. Real scale.</p>
          <ul>
            <li>Everything in Open Source</li>
            <li>Real-time SEO data (real SV, KD, CPC)</li>
            <li>Programmatic SEO (5000 pages)</li>
            <li>AI agent orchestration</li>
            <li>10 sites included</li>
            <li>2,000 AI credits/month</li>
          </ul>
          <a href="https://app.seoplant.io/register" class="btn btn-primary" style="width:100%;">Start Free Trial</a>
        </div>
        <div class="pricing-card">
          <h3>Agency</h3>
          <div class="price">$199<span>/mo</span></div>
          <p class="price-sub">For teams & agencies.</p>
          <ul>
            <li>Everything in Cloud</li>
            <li>50 sites included</li>
            <li>White-label reports</li>
            <li>Client dashboard</li>
            <li>API access</li>
            <li>5,000 AI credits/month</li>
          </ul>
          <a href="https://app.seoplant.io/register" class="btn btn-secondary" style="width:100%;">Get Started</a>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section" style="background:var(--color-dark);position:relative;overflow:hidden;text-align:center;">
    <div class="glow-orb" style="width:600px;height:600px;background:radial-gradient(circle,#3B82F6,transparent);top:-300px;left:50%;transform:translateX(-50%);opacity:0.1;"></div>
    <div class="container" style="position:relative;z-index:1;">
      <h2 style="color:var(--color-text-inverse);">Stop building websites.<br/>Start building <span class="gradient-text">traffic</span>.</h2>
      <p style="color:var(--color-text-muted);font-size:1.15rem;max-width:600px;margin:var(--space-lg) auto var(--space-2xl);">
        AI website builders give you a pretty site. SEO tools give you strategy.
        <strong style="color:var(--color-text-inverse);">SEOplant gives you both.</strong>
      </p>
      <div style="display:flex;gap:var(--space-md);justify-content:center;flex-wrap:wrap;">
        <a href="https://app.seoplant.io/register" class="btn btn-primary btn-lg">Start Building Free</a>
        <a href="https://github.com/seoplant/seoplant" class="btn btn-secondary btn-lg" style="border-color:rgba(255,255,255,0.2);color:var(--color-text-inverse);">View on GitHub</a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* Hero */
  .hero {
    padding-block: var(--space-5xl) var(--space-4xl);
    position: relative;
    overflow: hidden;
    text-align: center;
  }
  .hero-content {
    max-width: 800px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }
  .hero h1 {
    font-size: 4rem;
    letter-spacing: -0.03em;
    line-height: 1.1;
    margin-bottom: var(--space-lg);
  }
  .hero-sub {
    font-size: 1.2rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
    max-width: 600px;
    margin: 0 auto var(--space-2xl);
  }
  .hero-actions {
    display: flex;
    gap: var(--space-md);
    justify-content: center;
    margin-bottom: var(--space-3xl);
    flex-wrap: wrap;
  }

  /* Terminal */
  .hero-terminal {
    max-width: 600px;
    margin: 0 auto;
    background: #0d1117;
    border-radius: var(--radius-lg);
    border: 1px solid rgba(255,255,255,0.1);
    overflow: hidden;
    box-shadow: var(--shadow-xl);
    text-align: left;
  }
  .terminal-bar {
    display: flex;
    gap: 8px;
    padding: 12px 16px;
    background: #161b22;
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }
  .terminal-bar span {
    width: 12px; height: 12px; border-radius: 50%;
  }
  .terminal-bar span:nth-child(1) { background: #ff5f57; }
  .terminal-bar span:nth-child(2) { background: #febc2e; }
  .terminal-bar span:nth-child(3) { background: #28c840; }
  .hero-terminal pre {
    padding: 20px 24px;
    margin: 0;
    font-size: 0.9rem;
    line-height: 1.8;
    color: #c9d1d9;
    font-family: var(--font-mono);
    background: transparent;
    border: none;
  }
  .hero-terminal .dim { color: #6e7681; }
  .hero-terminal .kw { color: #79c0ff; }
  .hero-terminal .green { color: #56d364; }

  /* Sections */
  .section-header {
    text-align: center;
    margin-bottom: var(--space-lg);
  }
  .section-header p {
    margin-top: var(--space-sm);
    color: var(--color-text-muted);
  }

  /* Problem cards */
  .feature-card {
    background: var(--color-background);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-xl);
    transition: all var(--transition-base);
  }
  .feature-card:hover {
    border-color: var(--color-primary);
    box-shadow: var(--shadow-md);
  }
  .feature-card h3 { font-size: 1.1rem; margin-bottom: var(--space-sm); }
  .feature-card p { font-size: 0.95rem; margin-bottom: var(--space-md); }
  .feature-icon {
    width: 40px; height: 40px;
    border-radius: var(--radius-sm);
    display: flex; align-items: center; justify-content: center;
    font-weight: 700; font-size: 1rem;
    margin-bottom: var(--space-md);
  }
  .feature-tag {
    display: inline-block;
    font-size: 0.75rem; font-weight: 600;
    padding: 3px 10px; border-radius: 100px;
  }

  /* Steps (dark section) */
  .steps {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
    align-items: start;
  }
  .step {
    text-align: center;
    padding: 0 var(--space-md);
  }
  .step-num {
    width: 44px; height: 44px;
    border-radius: 50%;
    background: var(--color-gradient-subtle);
    color: white;
    display: flex; align-items: center; justify-content: center;
    font-weight: 700; font-size: 1.1rem;
    margin: 0 auto var(--space-md);
  }
  .step h4 { color: var(--color-text-inverse); margin-bottom: var(--space-sm); }
  .step p { color: var(--color-text-muted); font-size: 0.9rem; }
  .step-connector { display: none; }

  /* Pricing */
  .pricing-card {
    background: var(--color-background);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-2xl);
    text-align: center;
    position: relative;
  }
  .pricing-card.featured {
    border: 2px solid var(--color-primary);
    box-shadow: var(--shadow-lg);
    transform: scale(1.03);
  }
  .featured-badge {
    position: absolute;
    top: -14px; left: 50%; transform: translateX(-50%);
    background: var(--color-gradient-subtle);
    color: white;
    padding: 5px 20px;
    border-radius: 100px;
    font-size: 0.8rem;
    font-weight: 600;
  }
  .price {
    font-size: 3.2rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    margin: var(--space-md) 0 var(--space-xs);
  }
  .price span { font-size: 1rem; font-weight: 400; color: var(--color-text-muted); }
  .price-sub { color: var(--color-text-muted); margin-bottom: var(--space-xl); font-size: 0.9rem; }
  .pricing-card ul { list-style: none; padding: 0; text-align: left; margin-bottom: var(--space-xl); }
  .pricing-card li { padding: 6px 0; font-size: 0.9rem; color: var(--color-text-secondary); }
  .pricing-card li::before { content: "✓ "; color: var(--color-primary); font-weight: 700; }

  /* Grids */
  .cols-3 { grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); }
  .cols-2 { grid-template-columns: repeat(auto-fit, minmax(350px, 1fr)); }

  /* Table */
  .table-wrap {
    overflow-x: auto;
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-border);
    background: var(--color-background);
  }
  th.us { color: var(--color-primary); }
  td.yes { color: #059669; font-weight: 600; }
  td.no { color: var(--color-text-muted); }
  td.partial { color: #d97706; }

  @media (max-width: 768px) {
    .hero h1 { font-size: 2.5rem; }
    .hero-sub { font-size: 1rem; }
    .steps { grid-template-columns: 1fr; gap: var(--space-xl); }
    .pricing-card.featured { transform: none; }
    .hero-actions { flex-direction: column; align-items: center; }
  }
</style>
